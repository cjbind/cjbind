package cjbind_ffipublic const RTE_CACHE_LINE_MIN_SIZE_RTE_CACHE_LINE_MIN_SIZE: Int64 = 64public const RTE_CACHE_LINE_SIZE_RTE_CACHE_LINE_SIZE: Int64 = 64@Cpublic struct rte_kni_mbuf_rte_kni_mbuf {    public let buf_addr: CPointer<Unit>    public let buf_physaddr: UInt64    public let pad0: VArray<UInt8, $2>    //< Start address of data in segment buffer. *    public let data_off: UInt16    public let pad1: VArray<UInt8, $2>    //< Number of segments. *    public let nb_segs: UInt8    public let pad4: VArray<UInt8, $1>    //< Offload features. *    public let ol_flags: UInt64    public let pad2: VArray<UInt8, $4>    //< Total pkt len: sum of all segment data_len. *    public let pkt_len: UInt32    //< Amount of data in segment buffer. *    public let data_len: UInt16    public let pad3: VArray<UInt8, $8>    public let pool: CPointer<Unit>    public let next: CPointer<Unit>    public init(buf_addr: CPointer<Unit>, buf_physaddr: UInt64, pad0: VArray<UInt8, $2>, data_off: UInt16,        pad1: VArray<UInt8, $2>, nb_segs: UInt8, pad4: VArray<UInt8, $1>, ol_flags: UInt64, pad2: VArray<UInt8, $4>,        pkt_len: UInt32, data_len: UInt16, pad3: VArray<UInt8, $8>, pool: CPointer<Unit>, next: CPointer<Unit>) {        this.buf_addr = buf_addr        this.buf_physaddr = buf_physaddr        this.pad0 = pad0        this.data_off = data_off        this.pad1 = pad1        this.nb_segs = nb_segs        this.pad4 = pad4        this.ol_flags = ol_flags        this.pad2 = pad2        this.pkt_len = pkt_len        this.data_len = data_len        this.pad3 = pad3        this.pool = pool        this.next = next    }}@When[debug]let _ = {    =>        let size = sizeOf<rte_kni_mbuf_rte_kni_mbuf>()        if (size != 128) {            throw Exception("Size of rte_kni_mbuf_rte_kni_mbuf is not 128 but ${size} bytes")        }        let align = alignOf<rte_kni_mbuf_rte_kni_mbuf>()        if (align != 64) {            throw Exception("Alignment of rte_kni_mbuf_rte_kni_mbuf is not 64 but ${align} bytes")        }}